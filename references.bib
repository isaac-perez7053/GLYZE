	month = jan,
	year = {2005},
	doi = {10.1007/b99427},
	note = {Series Title: Advances in Polymer Science},
	pages = {105--149},
	file = {Huenberger_thermostat (2).pdf:files/1389/Huenberger_thermostat (2).pdf:application/pdf},
}

@article{zhao_prediction_2007,
	title = {Prediction of shear viscosities using periodic perturbation method and {OPLS} force field},
	volume = {260},
	copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},
	issn = {03783812},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0378381207003287},
	doi = {10.1016/j.fluid.2007.06.028},
	abstract = {The periodic perturbation method is applied to predict shear viscosities of liquid 1,4-butanediol, 1,3-butanediol, 1,2-butanediol, 2-methyl-1,3propanediol and 1,2,4-butanetriol under two thermodynamical conditions: T = 373 K, P = 0.1 MPa and T = 373 K, P = 250 MPa. A linear dependence of the calculated shear viscosities with respect to the applied perturbation forces is identiﬁed. Based on this ﬁnding, extrapolation of the calculated viscosities to zero perturbation force is applied to estimate the shear viscosities for the “undisturbed” ﬂuids. The uncertainties of the estimates are calculated using the block average method. The predicted values compare favorably with the experimental data. Although the force ﬁeld is optimized using equilibrium properties (liquid densities and vaporization enthalpies), calculated results demonstrate that the force ﬁeld can be used to predict the kinetic properties accurately. The force ﬁeld parameters are well transferable among different state points. However, transferring parameters among different molecules should be executed with caution.},
	language = {en},
	number = {2},
	urldate = {2025-12-04},
	journal = {Fluid Phase Equilibria},
	author = {Zhao, Lifeng and Wang, Xijun and Wang, Ling and Sun, Huai},
	month = nov,
	year = {2007},
	pages = {212--217},
	file = {1-s2.0-S0378381207003287-main.pdf:files/1391/1-s2.0-S0378381207003287-main.pdf:application/pdf},
}

